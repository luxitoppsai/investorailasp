# =============================================================================
# LLM Provider — set ONE of these keys. El sistema auto-detecta cuál usar.
# Si querés forzar un provider específico, seteá LLM_PROVIDER explícitamente.
# =============================================================================

# Option A: Anthropic Claude (recomendado — soporta prompt caching)
# ANTHROPIC_API_KEY=sk-ant-...

# Option B: OpenAI GPT
# OPENAI_API_KEY=sk-...

# Option C: Google Gemini
GEMINI_API_KEY=AIza...

# Forzar provider (anthropic | openai | gemini) — opcional, auto-detectado si no se setea
# LLM_PROVIDER=anthropic

# Modelos por provider — override opcional
# CLAUDE_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o
# GEMINI_MODEL=gemini-2.0-flash
# LLM_MAX_TOKENS=4096

# =============================================================================
# Otras APIs
# =============================================================================

# FRED (Federal Reserve Economic Data) — gratis en fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# Alpha Vantage (opcional) — gratis en alphavantage.co
# ALPHA_VANTAGE_API_KEY=your_av_key_here

# =============================================================================
# Sistema
# =============================================================================
LOG_LEVEL=INFO
